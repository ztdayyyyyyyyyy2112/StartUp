# ── Application ───────────────────────────────────────────────────────────
APP_NAME=NutriAI
APP_ENV=development           # development | staging | production
APP_VERSION=1.0.0
DEBUG=true
SECRET_KEY=change-this-to-a-random-64-char-string-in-production

# ── Server ────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Database (PostgreSQL) ─────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://nutriai:password@localhost:5432/nutriai_db
DATABASE_URL_SYNC=postgresql://nutriai:password@localhost:5432/nutriai_db
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# ── Redis ─────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_SECONDS=3600

# ── JWT Auth ──────────────────────────────────────────────────────────────
JWT_SECRET_KEY=another-random-secret-key-for-jwt
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── AI / ML ───────────────────────────────────────────────────────────────
# Khi có model thật, điền đường dẫn vào đây
AI_MODEL_PATH=./ml/checkpoints/recommendation_model.pt
AI_ENABLED=false              # true khi model đã sẵn sàng
OPENAI_API_KEY=               # nếu dùng GPT fallback
ANTHROPIC_API_KEY=            # nếu dùng Claude fallback

# ── External APIs (điền khi có đối tác) ───────────────────────────────────
USDA_API_KEY=                 # https://fdc.nal.usda.gov/api-guide.html
GENETICA_API_KEY=             # cho genomics integration (2032+)
GOOGLE_FIT_CLIENT_ID=
GOOGLE_FIT_CLIENT_SECRET=
APPLE_HEALTH_KEY=

# ── Email ─────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASSWORD=
EMAIL_FROM=noreply@nutriai.vn

# ── File Storage ──────────────────────────────────────────────────────────
STORAGE_BACKEND=local         # local | s3 | gcs
AWS_S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-southeast-1

# ── Monitoring ────────────────────────────────────────────────────────────
SENTRY_DSN=
LOG_LEVEL=INFO
